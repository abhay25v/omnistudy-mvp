# Copy this file to .env.local and update with your values

# API Gateway endpoint URL (from AWS Console)
NEXT_PUBLIC_API_URL=https://YOUR-API-ID.execute-api.us-east-1.amazonaws.com/process

# Optional: S3 bucket for file uploads (if using presigned URLs)
NEXT_PUBLIC_S3_BUCKET=omnistudy-audio-prod-2026
